generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationProvider {
  MERCADO_LIVRE
  MERCADO_PAGO
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

model Org {
  id                  String                  @id @default(cuid())
  name                String
  slug                String                  @unique
  taxRegime           TaxRegime               @default(SIMPLES_NACIONAL)
  simplesAnexo        String?
  rbt12               Float?
  effectiveTaxRate    Float?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  users               User[]
  products            Product[]
  integrations        IntegrationConnection[]
  auditLogs           AuditLog[]
}

model User {
  id            String    @id @default(cuid())
  orgId         String
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(OWNER)
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  org           Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  email       String
  ipAddress   String?
  success     Boolean
  attemptedAt DateTime @default(now())

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
}

model Product {
  id               String              @id @default(cuid())
  orgId            String
  name             String
  sku              String?
  weightKg         Float
  lengthCm         Float
  widthCm          Float
  heightCm         Float
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  org              Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  batches          PurchaseBatch[]
  scenarios        PricingScenario[]
  marketplaceLinks MarketplaceListing[]
  payments         FinancialPayment[]

  @@unique([orgId, sku])
  @@index([orgId])
}

model PurchaseBatch {
  id                String            @id @default(cuid())
  productId         String
  quantity          Int
  unitCostWithIpi   Float
  taxSubstitution   Float
  acquiredAt        DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  scenarios         PricingScenario[]
}

model PricingScenario {
  id                        String          @id @default(cuid())
  productId                 String
  batchId                   String?
  name                      String
  logisticsType             String
  freightPayer              String
  commissionRate            Float
  roas                      Float
  operationalCostRate       Float
  simpleTaxRate             Float
  ownIcmsRate               Float
  destinationIcmsRate       Float
  financialCostMonthlyRate  Float
  targetNetMarginRate       Float
  turnoverDays              Int
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  product                   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  batch                     PurchaseBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  results                   PricingResult[]
}

model PricingResult {
  id                       String          @id @default(cuid())
  scenarioId               String
  salePrice                Float
  freightCost              Float
  storageCost              Float
  finalUnitCost            Float
  grossMarginRate          Float
  multiplier               Float
  netMarginAmount          Float
  netMarginUnitAmount      Float
  roi                      Float
  annualizedRoi            Float
  revenueTotal             Float
  adsInvestment            Float
  statusJson               Json
  candidateJson            Json
  ratesEffectiveFrom       DateTime
  calculatedAt             DateTime        @default(now())
  scenario                 PricingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model IntegrationConnection {
  id                String              @id @default(cuid())
  orgId             String
  provider          IntegrationProvider
  status            ConnectionStatus    @default(ACTIVE)
  accountLabel      String
  externalUserId    String
  siteId            String?
  advertiserId      String?
  collectorId       String?
  scopes            String?
  tokenType         String?
  accessTokenEnc    String
  refreshTokenEnc   String?
  tokenExpiresAt    DateTime?
  metadataJson      Json?
  lastSyncedAt      DateTime?
  lastSyncStatus    String?
  lastSyncError     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  org               Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  listings          MarketplaceListing[]
  promotions        ListingPromotion[]
  adMetrics         ListingAdMetric[]
  payments          FinancialPayment[]
  webhookEvents     IntegrationWebhookEvent[]

  @@unique([orgId, provider, externalUserId])
  @@index([orgId])
}

model MarketplaceListing {
  id                  String                @id @default(cuid())
  connectionId        String
  productId           String?
  itemId              String                @unique
  siteId              String
  sellerId            String
  title               String
  status              String
  condition           String?
  domainId            String?
  categoryId          String?
  currencyId          String?
  listingTypeId       String?
  logisticType        String?
  officialStoreId     String?
  catalogListing      Boolean               @default(false)
  acceptsMercadoPago  Boolean               @default(true)
  price               Float
  originalPrice       Float?
  availableQuantity   Int?
  soldQuantity        Int?
  thumbnail           String?
  permalink           String?
  videoId             String?
  picturesJson        Json?
  attributesJson      Json?
  shippingJson        Json?
  variationsJson      Json?
  tagsJson            Json?
  rawJson             Json?
  lastSyncedAt        DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  connection          IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  product             Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  promotions          ListingPromotion[]
  adMetrics           ListingAdMetric[]
  payments            FinancialPayment[]

  @@index([connectionId, status])
  @@index([productId])
}

model ListingPromotion {
  id                 String                @id @default(cuid())
  connectionId       String
  listingId          String
  promotionId        String
  promotionType      String
  subType            String?
  status             String
  name               String?
  dealPrice          Float?
  originalPrice      Float?
  fixedPercentage    Float?
  fixedAmount        Float?
  sellerPercentage   Float?
  meliPercentage     Float?
  startDate          DateTime?
  finishDate         DateTime?
  rawJson            Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  connection         IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listing            MarketplaceListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, promotionId])
  @@index([connectionId, promotionType])
}

model ListingAdMetric {
  id                   String                @id @default(cuid())
  connectionId         String
  listingId            String
  metricDate           DateTime
  campaignId           String                @default("")
  clicks               Int?
  prints               Int?
  ctr                  Float?
  cost                 Float?
  cpc                  Float?
  acos                 Float?
  roas                 Float?
  cvr                  Float?
  sov                  Float?
  directAmount         Float?
  indirectAmount       Float?
  totalAmount          Float?
  unitsQuantity        Int?
  directUnitsQuantity  Int?
  indirectUnitsQuantity Int?
  advertisingItemsQuantity Int?
  organicUnitsQuantity Int?
  organicUnitsAmount   Float?
  rawJson              Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  connection           IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listing              MarketplaceListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, metricDate, campaignId])
  @@index([connectionId, metricDate])
}

model FinancialPayment {
  id                   String                @id @default(cuid())
  connectionId         String
  listingId            String?
  productId            String?
  paymentId            String                @unique
  externalReference    String?
  merchantOrderId      String?
  marketplaceOrderId   String?
  status               String
  statusDetail         String?
  paymentMethodId      String?
  paymentTypeId        String?
  currencyId           String?
  transactionAmount    Float
  totalPaidAmount      Float?
  netReceivedAmount    Float?
  shippingAmount       Float?
  marketplaceFeeAmount Float?
  mercadopagoFeeAmount Float?
  approvedAt           DateTime?
  paymentCreatedAt     DateTime?
  paymentUpdatedAt     DateTime?
  rawJson              Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  connection           IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listing              MarketplaceListing?   @relation(fields: [listingId], references: [id], onDelete: SetNull)
  product              Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([connectionId, paymentCreatedAt])
  @@index([listingId])
  @@index([productId])
}

model IntegrationWebhookEvent {
  id                String                @id @default(cuid())
  connectionId      String?
  provider          IntegrationProvider
  topic             String
  resource          String?
  externalEventId   String?
  payloadJson       Json
  processedAt       DateTime?
  createdAt         DateTime              @default(now())
  connection        IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([provider, topic])
  @@index([externalEventId])
}

model FreightRate {
  id            String    @id @default(cuid())
  label         String
  minWeightKg   Float
  maxWeightKg   Float?
  priceBandMin  Float
  priceBandMax  Float?
  freightCost   Float
  freightMode   String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  sourceUrl     String?
  createdAt     DateTime  @default(now())
}

model FullStorageRate {
  id                String    @id @default(cuid())
  sizeCategory      String
  maxLengthCm       Float?
  maxWidthCm        Float?
  maxHeightCm       Float?
  maxWeightKg       Float?
  dailyUnitRate     Float
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  agedStorageLabels Json?
  createdAt         DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  entity     String
  entityId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  userId     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, entity, entityId])
}
